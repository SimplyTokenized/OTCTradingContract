# ---------------------------------------------------------------------------
# OTC Trading Contract — environment template
#
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# `.env` is git-ignored and MUST NEVER be committed.
#
# Do NOT put private keys in this file for public networks. Sign transactions
# with a keystore account (`--account <name>`) or a hardware wallet instead.
# ---------------------------------------------------------------------------

# --- Deployment parameters (read by script/DeployOTC.s.sol) ---

# Base token: the ERC-20 being traded.
BASE_TOKEN=0x0000000000000000000000000000000000000000

# Default counterparty token approved at initialization (e.g. USDC).
# Mainnet USDC: 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
DEFAULT_COUNTERPARTY_TOKEN=0x0000000000000000000000000000000000000000

# Address that receives trading fees.
FEE_RECIPIENT=0x0000000000000000000000000000000000000000

# Admin address. Becomes the ProxyAdmin owner AND holds DEFAULT_ADMIN_ROLE /
# ADMIN_ROLE. For production, use a multisig or timelock — not an EOA.
ADMIN=0x0000000000000000000000000000000000000000

# --- Deployment tooling (used by npm run deploy:* scripts) ---

# Sender address that matches your keystore/hardware signer.
DEPLOYER=0x0000000000000000000000000000000000000000

# RPC endpoints.
TESTNET_RPC=
ETH_SEPOLIA_RPC=
AVALANCHE_FUJI_RPC=
MAINNET_RPC=

# Block explorer verification.
ETHERSCAN_API_KEY=
AVALANCHE_FUJI_VERIFIER_URL=
